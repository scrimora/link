{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Scrimora Link",
  "version": "0.1.0",
  "identifier": "app.scrimora.link",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Scrimora Link",
        "width": 760,
        "height": 520,
        "visible": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "scrimora-link"
        ]
      }
    }
  }
}
